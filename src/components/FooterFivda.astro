---
import {
  Footer,
  FooterCopyright,
  FooterDescription,
  FooterGroup,
  FooterMenu,
  FooterMenuItem,
  FooterMenuLink,
} from "@/components/ui/footer"
import { Icon } from "@/components/ui/icon"
import { Logo, LogoImage, LogoText } from "@/components/ui/logo"

interface Props {
  logo?: {
    src?: string
    alt?: string
    text?: string
    href?: string
  }
  description?: string
  links?: {
    text?: string
    href?: string
  }[]
  socials?: string[]
}

import Image from "astro/components/Image.astro"

const { logo, description, links, socials } = Astro.props
---

<Footer class="items-center bg-slate-900 p-0 gap-2 py-4">
  <FooterGroup class="items-center">
    <Logo>
      <LogoImage src={logo} alt=Fivda />
      <LogoText>Fivda</LogoText>
    </Logo>
    <FooterMenu orientation="horizontal">
      {
        links?.map(({ href, text }) => (
          <FooterMenuItem>
            <FooterMenuLink href={href}>{text}</FooterMenuLink>
          </FooterMenuItem>
        ))
      }
    </FooterMenu>
    <FooterMenu orientation="horizontal">
      {
        socials?.map((social) => {
          if (social === "https://bsky.app/profile/fivda.bsky.social") {
            return (
              <FooterMenuItem>
                <FooterMenuLink href="https://bsky.app/profile/fivda.bsky.social">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" stroke-linecap="round" stroke-linejoin="round" style="opacity:1;">
                    <path d="M21.247 5.646c.068-1.031-.695-1.98-1.702-1.724c-3.68.933-6.648 5.997-7.545 7.755c-.896-1.758-3.865-6.822-7.545-7.755c-1.007-.255-1.77.693-1.702 1.724l.3 4.466c.151 2.28 2.116 4.014 4.41 3.894l.49-.036c-.039.007-2.904.518-3.39 1.981c-.658 1.983 1.28 3.408 1.28 3.408c.022.024 1.894 2.096 3.765.899c1.463-.71 2.393-4.01 2.393-4.01s.929 3.3 2.392 4.01c1.88 1.203 3.762-.896 3.764-.9c.016-.01 1.935-1.431 1.28-3.407c-.49-1.473-3.391-1.98-3.391-1.98l.493.035c2.293.12 4.258-1.615 4.41-3.894z"/>
                  </svg>
                </FooterMenuLink>
              </FooterMenuItem>
            )
          }
          return (
          <FooterMenuItem>
            <FooterMenuLink href={social}>
              <Icon href={social} />
            </FooterMenuLink>
          </FooterMenuItem>
          )
        })
      }
    </FooterMenu>
  </FooterGroup>
  <FooterCopyright>{logo?.text}. Website made by <a cursor="pointer" class="font-bold" href="https://x.com/Doggibelle">Doggibelle</a></FooterCopyright>
</Footer>
