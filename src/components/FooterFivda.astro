---
import {
  Footer,
  FooterCopyright,
  FooterDescription,
  FooterGroup,
  FooterMenu,
  FooterMenuItem,
  FooterMenuLink,
} from "@/components/ui/footer"
import { Icon } from "@/components/ui/icon"
import { Logo, LogoImage, LogoText } from "@/components/ui/logo"

interface Props {
  logo?: {
    src?: string
    alt?: string
    text?: string
    href?: string
  }
  description?: string
  links?: {
    text?: string
    href?: string
  }[]
  socials?: string[]
}

import Image from "astro/components/Image.astro"

const { logo, description, links, socials } = Astro.props
---

<Footer class="items-center p-0 gap-2 py-4" style={"background-color: #A27F50"}>
  <FooterGroup class="items-center">
    <Logo>
      <LogoImage src={logo} alt=Fivda class="rounded-2xl" />
      <LogoText>Fivda</LogoText>
    </Logo>
    <FooterMenu orientation="horizontal">
      {
        links?.map(({ href, text }) => (
          <FooterMenuItem>
            <FooterMenuLink href={href}>{text}</FooterMenuLink>
          </FooterMenuItem>
        ))
      }
    </FooterMenu>
    <FooterMenu orientation="horizontal">
      {
        socials?.map((social) => {
          if (social === "https://bsky.app/profile/fivda.bsky.social") {
            return (
              <FooterMenuItem>
                <FooterMenuLink href="https://bsky.app/profile/fivda.bsky.social">
                  <svg class="size-8" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" stroke-linecap="round" stroke-linejoin="round" style="opacity:1;">
