---
import { getRelativeLocaleUrl } from "astro:i18n";
import { NavigationMenuItem, NavigationMenuLink, navigationMenuTriggerStyle } from "./ui/navigation-menu";

const locales = {
	'fr': 'French',
	'en': 'Anglais',
}

// Get current language and current path
const currentLang = Astro.currentLocale || 'en';
const currentPath = Astro.url.pathname
const pathWithoutLang = Astro.url.pathname

  .replace(`/${currentLang}/`, '/')  // Remove language prefix
  .replace(/^\//, '');  // Remove leading slash

console.log(currentLang)
console.log(currentPath)
console.log(pathWithoutLang)
---
<NavigationMenuItem value="switch">
{Object.entries(locales).filter(([lang]) => lang !== currentLang).map(([lang, label]) => {
      const href = `/${lang}/${pathWithoutLang}`
      console.log(href)
      return (
        <NavigationMenuLink href={href} class={`${navigationMenuTriggerStyle()} ${lang === currentLang ? 'active' : ''}`} class="bg-none p-4 font-bold bg-yellow-900/50 hover:bg-yellow-700/30 focus:bg-yellow-700/30">
			{label}
		</NavigationMenuLink>
      );
    })}
</NavigationMenuItem>