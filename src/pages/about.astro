---
import Layout from '@/layouts/Layout.astro';
import { Section, SectionProse, SectionActions, SectionContent } from '@/components/ui/section';
import Image from 'astro/components/Image.astro';
import fivda from '@/images/fivda.png';
import counterfestLogo from "@/images/Logo_DarkOrange_Transparent.png"
import vinyl from "@/images/vinyl.png"
import music from "@/images/music.png"
import kodamasounds from "@/images/kodama.webp"
import nitw from "@/images/nitw.png"
import kodamasoft from "@/images/kodamasoft.webp"
import vgmdb from "@/images/vgmdb.png"
import youtube from "@/images/youtube.png"
import twitch from "@/images/twitch.png"

import aboutJson from "@/data/about.json";

const BIRTHDAY: Date = new Date(1997, 5, 16);
const TODAY: Date = new Date();

const AGE_IN_MS: number = TODAY.getTime() - BIRTHDAY.getTime();
const AGE_IN_YEARS: number = AGE_IN_MS / (1000 * 60 * 60 * 24 * 365.25);

const AGE: number = Math.floor(AGE_IN_YEARS);

console.log(aboutJson);
// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout>
	<Section style={"background-color: #A27F50"}>
		<SectionContent>
			<SectionProse class="max-w-full">
				<h1 class=" text-center">Who am I ?</h1>
			</SectionProse>
			<SectionProse class="flex flex-row max-w-full">
				<div class="flex flex-col flex-1 justify-center">
					<Image src={fivda} alt="Fivda" width="10000" height="10000" class="w-1/2 h-auto self-center rounded-2xl"/>
				</div>
				<div class="flex flex-col flex-2  h-auto p-4 rounded-2xl" style={"background-color: #4B3832"}>
					<h2>Robin (Fivda / DJ ROUGE-GORGE)</h2>
					<h3 class="underline mt-0!">Music & Visual Arts</h3>
					<ul>
						<li>
							KodamaSoft / KodamaSounds Founder.
						</li>
						<li>
							COUNTERFEST RECORDS Founder
						</li>
						<li>
							Sound Producer & DJ
						</li>
					</ul>
					<p>she/her • {AGE} (June 16th, 1997) • France</p>
				</div>
			</SectionProse>
			<SectionProse class=" max-w-full">
				<p class="mx-4 text-center">
					{aboutJson.description}
				</p>
			</SectionProse>
		</SectionContent>
	</Section>
	<Section style={"background-color: #A27F50"}>
		<SectionContent>
			<SectionProse class=" max-w-full flex flex-col md:flex-row justify-around gap-2">
				<div class="p-4 rounded-2xl flex-1 w-fit h-fit max-w-fit" style={"background-color: #4B3832"}>
					<h1 class="text-left underline mb-4">Ongoing Projects</h1>

					<div class="flex flex-row">
						<Image src={counterfestLogo} alt="Counterfest" class="w-16 h-auto self-center p-2 mr-2"/>
						<div>
							<h6 class="underline m-0!">Since 2024</h6>
							<h6 class="m-0! font-bold">COUNTERFEST RECORDS</h6>
							<p>A new sublabel of KodamaSounds dedicated to our arrange albums & original tek albums, aimed towards free albums inspired by the bootleg & doujin scene.</p>
						</div>
					</div>

					<div class="flex flex-row mt-4">
						<Image src={vinyl} alt="DJing" class="w-16 h-auto self-center p-2 mr-2 invert"/>
						<div>
							<h6 class="underline m-0!">Since 2024</h6>
							<h6 class="m-0! font-bold">DJ Mixing</h6>
							<p>Started mixing all kinds of genres, and hoping to make live sets sooner or later.</p>
						</div>
					</div>

					<div class="flex flex-row mt-4">
						<Image src={music} alt="Music" class="w-16 h-auto self-center p-2 mr-2 invert"/>
						<div>
							<h6 class="underline m-0!">Since 2021</h6>
							<h6 class="m-0! font-bold">Sound Production / DTM</h6>
							<p>Producing music on Reaper. In a mostly techno & IDM style, and strives to craft songs in as many genres as possible.</p>
						</div>
					</div>

					<div class="flex flex-row mt-4">
						<Image src={vgmdb} alt="VGMDB" class="w-16 h-auto self-center p-2 mr-2"/>
						<div>
							<h6 class="m-0! font-bold">VGMdb Trusted Editor</h6>
							<p>2000+ albums added & 6000+ albums edited for the database, from VGM to Doujin Music.</p>
						</div>
					</div>

					<div class="flex flex-row mt-4">
						<Image src={kodamasounds} alt="KodamaSounds" class="w-16 h-auto self-center p-2 mr-2"/>
						<div>
							<h6 class="underline m-0!">Since 2020</h6>
							<h6 class="m-0! font-bold">KodamaSounds</h6>
							<p>Organized and supervised all KodamaSounds releases, featuring community driven arrange and original work albums.
								20+ hours/albums released, for +300 released songs, with more and more constantly coming.
							</p>
						</div>
					</div>

					<div class="flex flex-row mt-4">
						<Image src={nitw} alt="NITW" class="w-16 h-auto self-center p-2 mr-2"/>
						<div>
							<h6 class="underline m-0!">Since 2019</h6>
							<h6 class="m-0! font-bold">Night in the Woods French Fantranslator</h6>
							<p>Sole french fantranslator for Night in the Woods. Planned for completion in 2026.</p>
						</div>
					</div>

					<div class="flex flex-row mt-4">
						<Image src={kodamasoft} alt="KodamaSoft" class="w-16 h-auto self-center p-2 mr-2"/>
						<div>
							<h6 class="underline m-0!">Since 2018</h6>
							<h6 class="m-0! font-bold">KodamaSoft</h6>
							<p>Founder of a french doujin circle, working on the self developed KODAMA COMET games & visual novel projects.</p>
						</div>
					</div>
				</div>
				<div class="p-4 rounded-2xl flex-1 w-fit h-fit max-w-fit" style={"background-color: #4B3832"}>
					<h1 class="text-left underline mb-4">Past Projects</h1>

					<div class="flex flex-row mt-4">
						<div>
							<h6 class="underline m-0!">2024</h6>
							<h6 class="m-0! font-bold">A&R for Rolling Bassline Recordings</h6>
							<p>Contact & management accross worldwide artists on a commercial Hard Techno / Psystyle label.</p>
						</div>
					</div>

					<div class="flex flex-row mt-4">
						<Image src={twitch} alt="Twitch" class="w-16 h-auto self-center p-2 mr-2"/>
						<div>
							<h6 class="underline m-0!">2021</h6>
							<h6 class="m-0! font-bold">Twitch Streaming</h6>
							<p>Full time & rigorous English + French streams of various games.</p>
						</div>
					</div>

					<div class="flex flex-row mt-4">
						<div>
							<h6 class="underline m-0!">2019-2023</h6>
							<h6 class="m-0! font-bold">140VGM / 140ABGM Co-Founder</h6>
							<p>Administration of an account dedicated to posting cuts of VGM+Anime Music. Also hosted an user-requested radio program on
								Twitch, and interviewed various independant composers.
							</p>
						</div>
					</div>

					<div class="flex flex-row mt-4">
						<div>
							<h6 class="underline m-0!">2019</h6>
							<h6 class="m-0! font-bold">Katana Zero Speedrunning</h6>
							<p>Light competitor near the game's release, as well as early moderator.</p>
						</div>
					</div>

					<div class="flex flex-row mt-4">
						<div>
							<h6 class="underline m-0!">2018-2022</h6>
							<h6 class="m-0! font-bold">VGM Quiz Admin</h6>
							<p>Administration of a database and community for a VGM+Anime web music game.</p>
						</div>
					</div>

					<div class="flex flex-row mt-4">
						<Image src={youtube} alt="Youtube" class="w-16 h-auto self-center p-2 mr-2"/>
						<div>
							<h6 class="underline m-0!">2017-2018</h6>
							<h6 class="m-0! font-bold">Video-Game Critic</h6>
							<p>Made Youtube critics & reviews of games of all kinds.</p>
						</div>
					</div>

					<div class="flex flex-row mt-4">
						<div>
							<h6 class="underline m-0!">2017</h6>
							<h6 class="m-0! font-bold">LISA French Fantranslator</h6>
							<p>Self-developed a fan localization & fan patch for LISA the Painful & The Joyful in French.</p>
						</div>
					</div>

					<div class="flex flex-row mt-4">
						<div>
							<h6 class="underline m-0!">2016</h6>
							<h6 class="m-0! font-bold">SilvaGunner's Kazoo Master</h6>
							<p>Not my proudest.</p>
						</div>
					</div>

					<div class="flex flex-row mt-4">
						<div>
							<h6 class="underline m-0!">2016-2018</h6>
							<h6 class="m-0! font-bold">VGAOfficialArt Founder</h6>
							<p>Posted official artworks & concepts arts of video games and other forms of visual arts.</p>
						</div>
					</div>
				</div>
			</SectionProse>
		</SectionContent>
	</Section>
	<Section style={"background-color: #A27F50"}>
		<SectionContent>
			<SectionProse class=" max-w-full flex flex-col">
				<div class="p-4 rounded-2xl h-fit justify-center" style={"background-color: #4B3832"}>
					<h1 class="underline text-center">Passions & Likes</h1>
					<ul class="p-6">
						<li>Doujin, Music & DTM</li>
					</ul>
					<h1 class="underline text-center">Favorite Things</h1>
					<div class="flex-row flex flex-wrap">
						<div class="w-1/2 p-6">
							<h3>Music Artists</h3>
							<p class="m-0!">Taishi, Supire</p>
						</div>
						<div class="w-1/2 p-6">
							<h3>Games</h3>
							<p class="m-0!">Arcaea, Drakenier</p>
						</div>
						<div class="w-1/2 p-6">
							<h3>Anime</h3>
							<p class="m-0!">Evangelion, Tsuioku-hen</p>
						</div>
						<div class="w-1/2 p-6">
							<h3>Manga/Comics/Books</h3>
							<p class="m-0!">Houseki no Kuni, Koko no Hito</p>
						</div>
					</div>
				</div>
			</SectionProse>
		</SectionContent>
	</Section>
</Layout>
